{
  "productName": "Fydor",
  "version": "2.0.0",
  "identifier": "com.fydor.fydor",
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:3001",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Fydor",
        "url": "index.html",
        "width": 1000,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: data: blob:; font-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost https://fydor.vercel.app; object-src 'none'; base-uri 'none'; frame-src 'none'"
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/icon.icns",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/32x32.png",
      "icons/64x64.png",
      "icons/icon.ico"
    ],
    "targets": ["dmg", "nsis"]
  }
}
