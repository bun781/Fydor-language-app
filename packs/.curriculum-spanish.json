    { "n": 1, "cp": "A0", "title": "Hello and goodbye", "topic": "Greetings, introducing yourself", "grammar": ["me llamo / ¿cómo te llamas?", "formal vs informal usted/tú (intro)"], "vocab": ["hola", "buenos días", "buenas tardes", "buenas noches", "adiós", "hasta luego", "¿cómo estás?", "bien", "gracias", "por favor", "me llamo", "encantado/encantada", "sí", "no", "y tú"], "idioms": [], "recycles": [] },
