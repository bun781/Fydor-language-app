  "grammarGuide": {
    "schemaVersion": 1,
    "rules": [
      {
        "id": "la",
        "title": "Là for identity and roles",
        "overview": "Là links a person or thing to an identity, role, category, or description. It is common with nouns, professions, and introductions.",
        "situations": [
          {
            "title": "Core use",
            "explanation": "Là links a person or thing to an identity, role, category, or description. It is common with nouns, professions, and introductions.",
            "unitIndexes": [
              0
            ]
          }
        ],
        "contrasts": [
          "Use là for what something is, not before an ordinary action verb."
        ],
        "commonMistakes": [
          "Use là for what something is, not before an ordinary action verb."
        ]
      },
      {
        "id": "question",
        "title": "Question words in their normal position",
        "overview": "Ai, gì, ở đâu, khi nào, thế nào, và tại sao stay where the missing information would appear. Vietnamese does not move them to the front like English often does.",
        "situations": [
          {
            "title": "Core use",
            "explanation": "Ai, gì, ở đâu, khi nào, thế nào, và tại sao stay where the missing information would appear. Vietnamese does not move them to the front like English often does.",
            "unitIndexes": [
              1,
              7,
              10,
              13
            ]
          }
        ],
        "contrasts": [
          "Question words keep statement word order; yes-no questions can use không or à depending on context."
        ],
        "commonMistakes": [
          "Question words keep statement word order; yes-no questions can use không or à depending on context."
        ]
      },
      {
        "id": "time",
        "title": "Time expressions before the action",
        "overview": "Vietnamese commonly places time expressions before the verb, and the verb itself does not conjugate for tense. Context words such as hôm qua, đang, rồi, and sẽ carry timing.",
        "situations": [
          {
            "title": "Core use",
            "explanation": "Vietnamese commonly places time expressions before the verb, and the verb itself does not conjugate for tense. Context words such as hôm qua, đang, rồi, and sẽ carry timing.",
            "unitIndexes": [
              2,
              3,
              9,
              11,
              14
            ]
          }
        ],
        "contrasts": [
          "Do not add an English-style past-tense ending to Vietnamese verbs."
        ],
        "commonMistakes": [
          "Do not add an English-style past-tense ending to Vietnamese verbs."
        ]
      },
      {
        "id": "dang",
        "title": "Đang for actions in progress",
        "overview": "Đang before a verb marks an action that is happening or developing at the relevant time.",
        "situations": [
          {
            "title": "Core use",
            "explanation": "Đang before a verb marks an action that is happening or developing at the relevant time.",
            "unitIndexes": [
              3,
              8,
              15
            ]
          }
        ],
        "contrasts": [
          "Đang describes an ongoing action; it does not automatically mean every present-tense verb."
        ],
        "commonMistakes": [
          "Đang describes an ongoing action; it does not automatically mean every present-tense verb."
        ]
      },
      {
        "id": "location",
        "title": "Ở for location",
        "overview": "Ở introduces a place where a person or thing is located. It can also appear in common location phrases such as ở nhà and ở trường.",
        "situations": [
          {
            "title": "Core use",
            "explanation": "Ở introduces a place where a person or thing is located. It can also appear in common location phrases such as ở nhà and ở trường.",
            "unitIndexes": [
              4,
              5,
              7,
              13,
              15
            ]
          }
        ],
        "contrasts": [
          "Use ở for location, not as a general equivalent of English ‘is’."
        ],
        "commonMistakes": [
          "Use ở for location, not as a general equivalent of English ‘is’."
        ]
      },
      {
        "id": "measure",
        "title": "Classifiers after numbers",
        "overview": "Vietnamese often uses classifiers such as cái, chiếc, quyển, tờ, ly, and người between a number or demonstrative and a noun.",
        "situations": [
          {
            "title": "Core use",
            "explanation": "Vietnamese often uses classifiers such as cái, chiếc, quyển, tờ, ly, and người between a number or demonstrative and a noun.",
            "unitIndexes": [
              2,
              5,
              6,
              9,
              14
            ]
          }
        ],
        "contrasts": [
          "Choose a classifier that fits the noun instead of translating English number + noun word for word."
        ],
        "commonMistakes": [
          "Choose a classifier that fits the noun instead of translating English number + noun word for word."
        ]
      },
      {
        "id": "cua",
        "title": "Của for possession",
        "overview": "Của links an owner to a noun: A của B means B's A or A belonging to B. Possessive pronouns can also be used when the noun is understood.",
        "situations": [
          {
            "title": "Core use",
            "explanation": "Của links an owner to a noun: A của B means B's A or A belonging to B. Possessive pronouns can also be used when the noun is understood.",
            "unitIndexes": [
              0,
              4,
              8,
              9,
              10,
              13
            ]
          }
        ],
        "contrasts": [
          "Keep the owner and possessed noun in the Vietnamese order: noun + của + owner."
        ],
        "commonMistakes": [
          "Keep the owner and possessed noun in the Vietnamese order: noun + của + owner."
        ]
      },
      {
        "id": "da",
        "title": "Đã, rồi, chưa for completed events",
        "overview": "Đã marks an earlier or completed event, rồi often confirms that something has happened, and chưa asks whether it has happened yet or says it has not.",
        "situations": [
          {
            "title": "Core use",
            "explanation": "Đã marks an earlier or completed event, rồi often confirms that something has happened, and chưa asks whether it has happened yet or says it has not.",
            "unitIndexes": [
              2,
              5,
              9,
              11,
              14,
              16,
              18
            ]
          }
        ],
        "contrasts": [
          "Vietnamese marks aspect and time with separate words; verbs do not change form."
        ],
        "commonMistakes": [
          "Vietnamese marks aspect and time with separate words; verbs do not change form."
        ]
      },
      {
        "id": "modal",
        "title": "Có thể, muốn, cần, nên, phải",
        "overview": "Modal expressions come before the main verb. Có thể expresses ability or possibility, muốn intention, cần need, nên advice, and phải obligation.",
        "situations": [
          {
            "title": "Core use",
            "explanation": "Modal expressions come before the main verb. Có thể expresses ability or possibility, muốn intention, cần need, nên advice, and phải obligation.",
            "unitIndexes": [
              1,
              7,
              8,
              9,
              11,
              13,
              16,
              18
            ]
          }
        ],
        "contrasts": [
          "Do not add a second modal or an English infinitive marker after these expressions."
        ],
        "commonMistakes": [
          "Do not add a second modal or an English infinitive marker after these expressions."
        ]
      },
      {
        "id": "comparison",
        "title": "Comparisons with hơn and bằng",
        "overview": "Put hơn after an adjective or adverb to mean more or -er, and use bằng for equality. Không bằng means not as…as.",
        "situations": [
          {
            "title": "Core use",
            "explanation": "Put hơn after an adjective or adverb to mean more or -er, and use bằng for equality. Không bằng means not as…as.",
            "unitIndexes": [
              4,
              5,
              6,
              8,
              13,
              15
            ]
          }
        ],
        "contrasts": [
          "Hơn follows the quality being compared; it does not come before the adjective as English ‘more’ does."
        ],
        "commonMistakes": [
          "Hơn follows the quality being compared; it does not come before the adjective as English ‘more’ does."
        ]
      },
      {
        "id": "reason",
        "title": "Vì… nên… for reasons and results",
        "overview": "Vì introduces a reason and nên introduces the result. The pair explains choices, problems, delays, and solutions.",
        "situations": [
          {
            "title": "Core use",
            "explanation": "Vì introduces a reason and nên introduces the result. The pair explains choices, problems, delays, and solutions.",
            "unitIndexes": [
              3,
              5,
              9,
              11,
              12,
              16,
              17
            ]
          }
        ],
        "contrasts": [
          "Vì gives the cause and nên gives the consequence; keep the logic clear."
        ],
        "commonMistakes": [
          "Vì gives the cause and nên gives the consequence; keep the logic clear."
        ]
      },
      {
        "id": "condition",
        "title": "Nếu… thì… for conditions",
        "overview": "Nếu introduces a condition and thì introduces the expected result. This pattern is useful for plans, warnings, and emergency instructions.",
        "situations": [
          {
            "title": "Core use",
            "explanation": "Nếu introduces a condition and thì introduces the expected result. This pattern is useful for plans, warnings, and emergency instructions.",
            "unitIndexes": [
              6,
              7,
              11,
              15,
              17,
              18,
              19
            ]
          }
        ],
        "contrasts": [
          "Thì marks the result; it does not mean every English use of ‘then’."
        ],
        "commonMistakes": [
          "Thì marks the result; it does not mean every English use of ‘then’."
        ]
      },
      {
        "id": "polite",
        "title": "Polite requests with xin, vui lòng, and giúp",
        "overview": "Xin and vui lòng make requests polite, while giúp tôi asks someone to help with a specific action. Tone and relationship still matter.",
        "situations": [
          {
            "title": "Core use",
            "explanation": "Xin and vui lòng make requests polite, while giúp tôi asks someone to help with a specific action. Tone and relationship still matter.",
            "unitIndexes": [
              8,
              9,
              10,
              13,
              17,
              18
            ]
          }
        ],
        "contrasts": [
          "A natural request usually states the action clearly instead of repeating xin in every sentence."
        ],
        "commonMistakes": [
          "A natural request usually states the action clearly instead of repeating xin in every sentence."
        ]
      },
      {
        "id": "passive",
        "title": "Bị and được passive patterns",
        "overview": "Bị commonly introduces an unwanted or harmful passive event, while được often introduces a beneficial or permitted one.",
        "situations": [
          {
            "title": "Core use",
            "explanation": "Bị commonly introduces an unwanted or harmful passive event, while được often introduces a beneficial or permitted one.",
            "unitIndexes": [
              6,
              12,
              16,
              17,
              18,
              19
            ]
          }
        ],
        "contrasts": [
          "Use a passive pattern when the affected person or object is more important than the actor."
        ],
        "commonMistakes": [
          "Use a passive pattern when the affected person or object is more important than the actor."
        ]
      },
      {
        "id": "report",
        "title": "Sequence and reported information",
        "overview": "First, then, sau đó, lúc đó, and theo lời… organize a report. They make an incident or work update easy to follow.",
        "situations": [
          {
            "title": "Core use",
            "explanation": "First, then, sau đó, lúc đó, and theo lời… organize a report. They make an incident or work update easy to follow.",
            "unitIndexes": [
              10,
              11,
              12,
              18,
              19
            ]
          }
        ],
        "contrasts": [
          "Give time, place, people, actions, and results in a clear order."
        ],
        "commonMistakes": [
          "Give time, place, people, actions, and results in a clear order."
        ]
      }
    ]
